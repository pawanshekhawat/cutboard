# CutBoard server runtime config

# Project root (defaults to current working directory)
CUTBOARD_PROJECT_ROOT=.

# Optional explicit paths (leave commented to derive from PROJECT_ROOT)
# CUTBOARD_PROJECT_PATH=./project.json
# CUTBOARD_ASSETS_PATH=./assets

# API server port
CUTBOARD_PORT=3001

# Comma-separated CORS origins for Studio
CUTBOARD_CORS_ORIGINS=http://localhost:5173,http://localhost:4173
